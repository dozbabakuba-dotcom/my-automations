# Sem patri lokalni konfigurace a tajne hodnoty.
# Nikdy necommituj skutecny .env soubor.

AUTOMATION_GREETING=Ahoj

# OpenAI API key for AI-powered audit reports.
OPENAI_API_KEY=

# Optional audit configuration.
EIDAS_AUDIT_MODEL=gpt-5-mini
EIDAS_AUDIT_URL=https://eidas.tools
EIDAS_AUDIT_REPORT_DIR=reports/eidas-tools

# Optional: set this if eidas.tools shows the password screen to the automation.
EIDAS_AUDIT_PASSWORD=
